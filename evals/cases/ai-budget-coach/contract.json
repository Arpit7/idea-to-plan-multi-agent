{
  "meta": {
    "case_id": "ai-budget-coach",
    "created_at": "2026-06-09",
    "description": "Build a local-first AI budgeting coach for one user. Ingest bank and credit-card CSVs, auto-categorize transactions with"
  },
  "requirements": [
    {
      "id": "R1",
      "term": "t a monthly Markdown coaching",
      "description": "Provide t a monthly Markdown coaching capability",
      "match_patterns": [
        "(?i)t\\ a\\ monthly\\ Markdown\\ coaching"
      ]
    },
    {
      "id": "R2",
      "term": "markdown output",
      "description": "Output in Markdown format",
      "match_patterns": [
        "(?i)markdown"
      ]
    },
    {
      "id": "R3",
      "term": "deterministic model",
      "description": "Uses deterministic computation (not probabilistic/LLM-driven)",
      "match_patterns": [
        "(?i)deterministic.*(model|comput|engine|math|calcul)"
      ]
    },
    {
      "id": "R4",
      "term": "LLM narration from structured only",
      "description": "LLM narrates from structured outputs only, never raw data",
      "match_patterns": [
        "(?i)llm.*narrat",
        "(?i)structured.*out.*only",
        "(?i)never.*raw"
      ]
    },
    {
      "id": "R5",
      "term": "local-first",
      "description": "All processing is local, no cloud dependency",
      "match_patterns": [
        "(?i)local.?(first|only)",
        "(?i)no.*cloud"
      ]
    }
  ],
