{
  "meta": {
    "case_id": "epfo-nps-fetcher",
    "created_at": "2026-06-09",
    "description": "Create a local desktop application for fetching EPFO and NPS data from the government portals (EPFO UAN member portal an"
  },
  "requirements": [
    {
      "id": "R1",
      "term": "fetch EPFO and NPS data",
      "description": "Fetch EPFO (UAN) and NPS (CRA) data from the government portals given user credentials",
      "match_patterns": ["(?i)(EPFO|UAN).*(NPS|CRA)", "(?i)fetch.*(EPFO|NPS)", "(?i)(scrape|automat).*(login|portal|passbook)"]
    },
    {
      "id": "R2",
      "term": "login automation",
      "description": "Automate login to government portals using stored credentials",
      "match_patterns": ["(?i)(automat|headless|playwright).*login", "(?i)login.*(automat|portal)"]
    },
    {
      "id": "R3",
      "term": "unified local store",
      "description": "Normalize fetched data into a unified local store",
      "match_patterns": ["(?i)normaliz.*(store|local|unified)", "(?i)unified.*(store|local)"]
    },
    {
      "id": "R4",
      "term": "consolidated dashboard",
      "description": "Present a consolidated retirement-savings dashboard with contribution history and interest",
      "match_patterns": ["(?i)(dashboard|consolidated).*(retirement|contribution|savings)", "(?i)contribution.*history"]
    },
    {
      "id": "R5",
      "term": "credentials stay local",
      "description": "Credentials and data never leave the machine; stored encrypted",
      "match_patterns": ["(?i)(never.*leave|local|offline)", "(?i)(keyring|encrypt|sqlcipher)"]
    }
  ],
  "non_goals": [
