{
  "meta": {
    "case_id": "portfolio-drift-analyzer",
    "created_at": "2026-06-09",
    "description": "Build a local read-only portfolio drift analyzer. Ingest holdings CSVs across equity, mutual funds, and fixed deposits, "
  },
  "requirements": [
    {
      "id": "R1",
      "term": "Output a Markdown drift",
      "description": "Provide Output a Markdown drift capability",
      "match_patterns": [
        "(?i)Output\\ a\\ Markdown\\ drift"
      ]
    },
    {
      "id": "R2",
      "term": "markdown output",
      "description": "Output in Markdown format",
      "match_patterns": [
        "(?i)markdown"
      ]
    },
    {
      "id": "R3",
      "term": "deterministic model",
      "description": "Uses deterministic computation (not probabilistic/LLM-driven)",
      "match_patterns": [
        "(?i)deterministic.*(model|comput|engine|math|calcul)"
      ]
    },
    {
      "id": "R4",
      "term": "LLM narration from structured only",
      "description": "LLM narrates from structured outputs only, never raw data",
      "match_patterns": [
        "(?i)llm.*narrat",
        "(?i)structured.*out.*only",
        "(?i)never.*raw"
      ]
    }
  ],
