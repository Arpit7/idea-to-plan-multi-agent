{
  "meta": {
    "case_id": "ai-financial-doc-qa",
    "created_at": "2026-06-09",
    "description": "Create a local Gen-AI question-answering assistant over a user's personal financial documents (bank statements, salary s"
  },
  "requirements": [
    {
      "id": "R1",
      "term": "on-device RAG index",
      "description": "Build an on-device RAG index over personal financial documents",
      "match_patterns": ["(?i)(RAG|retrieval).*(index|on.?device|local)", "(?i)(embedding|vector).*(index|store|faiss)"]
    },
    {
      "id": "R2",
      "term": "grounded answers with citations",
      "description": "LLM answers grounded strictly in retrieved chunks with citations",
      "match_patterns": ["(?i)(grounded|cite|citation).*(chunk|source|retriev)", "(?i)answer.*(grounded|cite|source)"]
    },
    {
      "id": "R3",
      "term": "natural-language Q&A",
      "description": "Answer natural-language questions over documents",
      "match_patterns": ["(?i)(natural.?language|question).*(answer|query|Q&A)", "(?i)question.?answering"]
    },
    {
      "id": "R4",
      "term": "fully offline",
      "description": "Everything runs offline; documents never leave the machine",
      "match_patterns": ["(?i)offline", "(?i)never.*leave", "(?i)on.?device"]
    },
    {
      "id": "R5",
      "term": "document ingestion",
      "description": "Ingest PDF, TXT, and CSV documents into the index",
      "match_patterns": ["(?i)(ingest|index).*(pdf|document|txt)", "(?i)(pdf|txt|csv).*(ingest|index|document)"]
    }
  ],
  "non_goals": [
    {
      "id": "NG1",
      "term": "cloud embeddings",
      "leak_patterns": [
        "(?i)embeddings.*(?:implement|phase|build|component|create|route|endpoint|schema|module)",
