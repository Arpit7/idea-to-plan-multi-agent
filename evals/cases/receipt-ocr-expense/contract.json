{
  "meta": {
    "case_id": "receipt-ocr-expense",
    "created_at": "2026-06-09",
    "description": "Create a local expense tracker that ingests photos or PDFs of receipts, extracts merchant, date, line items, and total u"
  },
  "requirements": [
    {
      "id": "R1",
      "term": "on-device OCR extraction",
      "description": "Extract merchant, date, line items, and total from receipt images/PDFs using on-device OCR",
      "match_patterns": ["(?i)(ocr|tesseract).*(extract|receipt)", "(?i)extract.*(merchant|total|line.?item)"]
    },
    {
      "id": "R2",
      "term": "LLM name normalization from structured only",
      "description": "Local LLM normalizes merchant names and suggests category from extracted structured fields only",
      "match_patterns": ["(?i)(llm|normaliz).*(merchant|category)", "(?i)structured.*field"]
    },
    {
      "id": "R3",
      "term": "fixed category taxonomy",
      "description": "Suggest a category from a fixed taxonomy",
      "match_patterns": ["(?i)(fixed|taxonomy).*categor", "(?i)categor.*(fixed|taxonomy)"]
    },
    {
      "id": "R4",
      "term": "local DB storage",
      "description": "Store expenses in a local encrypted DB",
      "match_patterns": ["(?i)(local|sqlite|encrypt).*(db|store)", "(?i)store.*expense"]
    },
    {
      "id": "R5",
      "term": "markdown expense summary",
      "description": "Export a monthly Markdown expense summary",
      "match_patterns": ["(?i)markdown.*(summary|expense)", "(?i)monthly.*summary"]
    },
    {
      "id": "R6",
      "term": "fully offline",
      "description": "Runs fully offline; receipt images never leave the device",
      "match_patterns": ["(?i)offline", "(?i)on.?device", "(?i)never.*(leave|off.?device)"]
    }
  ],
