{
  "meta": {
    "case_id": "subscription-auditor",
    "created_at": "2026-06-09",
    "description": "Build a local tool that detects recurring subscriptions and silent price hikes from imported bank and card statements. A"
  },
  "requirements": [
    {
      "id": "R1",
      "term": "a Markdown subscription audit",
      "description": "Provide a Markdown subscription audit capability",
      "match_patterns": [
        "(?i)a\\ Markdown\\ subscription\\ audit"
      ]
    },
    {
      "id": "R2",
      "term": "markdown output",
      "description": "Output in Markdown format",
      "match_patterns": [
        "(?i)markdown"
      ]
    },
    {
      "id": "R3",
      "term": "deterministic model",
      "description": "Uses deterministic computation (not probabilistic/LLM-driven)",
      "match_patterns": [
        "(?i)deterministic.*(model|comput|engine|math|calcul)"
      ]
    },
    {
      "id": "R4",
      "term": "LLM narration from structured only",
      "description": "LLM narrates from structured outputs only, never raw data",
      "match_patterns": [
        "(?i)llm.*narrat",
        "(?i)structured.*out.*only",
        "(?i)never.*raw"
      ]
    }
  ],
