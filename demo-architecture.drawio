  <diagram id="demo13-arch" name="Demo - Idea to Plan">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ============ TITLE ============ -->
        <mxCell id="title" value="&lt;b&gt;Demo — Idea to Plan&lt;/b&gt;&lt;br&gt;Multi-Agent Planning Architecture (mol-idea-to-plan v4 + Eval)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="1000" height="50" as="geometry" />
        </mxCell>

        <!-- ============ ROW 1: HUMAN ============ -->
        <mxCell id="human" value="&lt;b&gt;Human (Presenter)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Provides scoped IDEA + semi-structured CONTEXT&lt;br&gt;Answers the clarify gate (step 4)&lt;br&gt;Reviews eval report (step 9)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=13;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="100" width="360" height="110" as="geometry" />
        </mxCell>

        <!-- ============ ROW 2: EVAL GATE (INPUT) ============ -->
        <mxCell id="eval_input" value="&lt;b&gt;① Eval Gate — Input Validation&lt;/b&gt;&lt;br&gt;&lt;br&gt;context_parser.py (deterministic, no LLM)&lt;br&gt;• Validates CONTEXT has Non-goals: + Stack: labels&lt;br&gt;• Rejects run immediately if missing (0 tokens spent)&lt;br&gt;• Generates eval-contract.json from CONTEXT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=12;align=center;arcSize=8;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="600" y="270" width="560" height="120" as="geometry" />
        </mxCell>

        <!-- ============ ROW 3: MAYOR ============ -->
        <mxCell id="mayor" value="&lt;b&gt;mayor — Coordinator Agent&lt;/b&gt;&lt;br&gt;&lt;br&gt;Walks 9 steps (mol-idea-to-plan v4)&lt;br&gt;Fan-out: batch-creates leg beads, slings to reviewers&lt;br&gt;Fan-in: reads inbox once per phase, synthesizes artifacts&lt;br&gt;Owns the single human gate&lt;br&gt;&lt;i&gt;Does NO review work itself&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=13;align=center;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="600" y="450" width="560" height="160" as="geometry" />
        </mxCell>

